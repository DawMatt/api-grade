    "backstage-backend",
    "api",
    "openapi",
    "asyncapi",
    "quality",
    "grading"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DawMatt/api-grade.git"
  },
  "homepage": "https://github.com/DawMatt/api-grade/tree/main/packages/backstage-plugin-api-grade-backend#readme",
  "bugs": {
    "url": "https://github.com/DawMatt/api-grade/issues"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
